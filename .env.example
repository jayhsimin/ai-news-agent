# ═══════════════════════════════════════════════
#  AI News Agent - 環境變數設定範本
#  複製此檔案為 .env 並填入實際值
# ═══════════════════════════════════════════════

# ── 應用程式 ──
APP_NAME="AI News Agent"
DEBUG=false
LOG_LEVEL=INFO

# ── Redis（Docker 內部網路，通常不需修改）──
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Qdrant（Docker 內部網路）──
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=ai_news
VECTOR_SIZE=384

# ── Ollama LLM（本地，免費）──
OLLAMA_BASE_URL=http://ollama:11434
# 可選：qwen2.5:7b 或 llama3.1:8b
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=120

# ── Embedding 模型 ──
EMBEDDING_MODEL=all-MiniLM-L6-v2
# 去重相似度門檻（0~1，越高越嚴格）
SIMILARITY_THRESHOLD=0.85

# ── Groq API（GitHub Actions 模式使用，免費）──
# 申請：https://console.groq.com → API Keys → Create API Key
# 免費方案：14,400 req/day，30 req/min（llama-3.1-8b-instant）
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ── Reddit API（免費，需在 https://www.reddit.com/prefs/apps 建立 App）──
# App 類型選 "script"
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=ai-news-agent/1.0 by YourUsername
# 要監控的 subreddits（逗號分隔）
REDDIT_SUBREDDITS=LocalLLaMA,MachineLearning,singularity,artificial
REDDIT_POST_LIMIT=25

# ── Telegram Bot（免費，從 @BotFather 取得）──
# 1. 在 Telegram 找 @BotFather
# 2. /newbot 建立 bot 取得 token
# 3. 把 bot 加入頻道/群組並設為 admin
# 4. 取得 chat_id（可用 @userinfobot 查詢）
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_ENABLED=true

# ── 採集排程（分鐘）──
COLLECT_INTERVAL_MINUTES=30

# ── 推播品質控管 ──
# 最低相關性分數才推播（0~10）
MIN_RELEVANCE_SCORE=6.0
